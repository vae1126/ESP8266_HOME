# ESP8266 Smart Home Controller - Default Configuration

# Flash配置
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHMODE_DOUT=y
CONFIG_ESPTOOLPY_FLASHFREQ_40M=y

# MQTT Broker
CONFIG_MQTT_BROKER_URL="mqtt://47.121.26.212:1883"

# Log level
CONFIG_LOG_DEFAULT_LEVEL=3
CONFIG_LOG_DEFAULT_LEVEL_INFO=y
CONFIG_LOG_MAXIMUM_LEVEL=3
CONFIG_LOG_MAXIMUM_LEVEL_INFO=y

# Device Configuration - 默认不启用任何设备
# 按需取消注释启用对应设备类型
#
# === PWM 单色灯 ===
# CONFIG_DEVICE_TYPE_LIGHT_PWM_SINGLE=y
# CONFIG_PWM_SINGLE_COUNT=1
# CONFIG_PWM_SINGLE_1_GPIO=2
# CONFIG_PWM_SINGLE_1_ACTIVE_HIGH is not set
#
# === PWM RGB 灯 ===
# CONFIG_DEVICE_TYPE_LIGHT_PWM_RGB=y
# CONFIG_PWM_RGB_COUNT=1
# CONFIG_PWM_RGB_1_R_GPIO=4
# CONFIG_PWM_RGB_1_G_GPIO=5
# CONFIG_PWM_RGB_1_B_GPIO=6
#
# === WS2812 灯带 ===
# CONFIG_DEVICE_TYPE_LIGHT_WS2812=y
# CONFIG_WS2812_COUNT=1
# CONFIG_WS2812_1_GPIO=3
# CONFIG_WS2812_1_NUM=10
#
# === 开关/继电器 ===
# CONFIG_DEVICE_TYPE_SWITCH=y
# CONFIG_SWITCH_COUNT=1
# CONFIG_SWITCH_1_GPIO=7

# Main task stack size
CONFIG_ESP_MAIN_TASK_STACK_SIZE=3584

# Task Watchdog Timer - 启用任务看门狗，超时时间5秒
CONFIG_ESP_TASK_WDT=y
CONFIG_ESP_TASK_WDT_TIMEOUT_S=5
CONFIG_ESP_TASK_WDT_CHECK_IDLE_TASK_CPU0=n
